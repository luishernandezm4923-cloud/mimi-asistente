<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FBF8F2">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MIMI"
        android:textSize="56sp"
        android:textStyle="bold"
        android:textColor="#12312B" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="40dp"
        android:text="Monitor Inteligente de Medicinas e Incidencias"
        android:textSize="16sp"
        android:textColor="#5C6E68"
        android:gravity="center" />

    <Button
        android:id="@+id/startButton"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:text="Activar\nMIMI"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#12312B" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Toque el botón para activar la escucha"
        android:textSize="18sp"
        android:textColor="#12312B"
        android:gravity="center" />

    <TextView
        android:id="@+id/transcriptText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text=""
        android:textSize="15sp"
        android:textStyle="italic"
        android:textColor="#5C6E68"
        android:gravity="center" />

    <Button
        android:id="@+id/emergencyButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:padding="20dp"
        android:text="🚨 EMERGENCIA — Llamar ahora"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#C24B3E" />

    <Button
        android:id="@+id/settingsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:padding="14dp"
        android:text="⚙️ Configurar contactos de confianza"
        android:textSize="16sp"
        android:textColor="#12312B"
        android:backgroundTint="#E8C376" />

</LinearLayout>
